[pytest]
env =
    ENVIRONMENT={ENVIRONMENT}
    NOVU_SECRET_KEY={NOVU_SECRET_KEY}
    REDIS_URI={REDIS_URI}
    SURREAL_URI={SURREAL_URI}
    SURREAL_PASS={SURREAL_PASS}
    SURREAL_USER={SURREAL_USER}
    GOOGLE_CLOUD_PROJECT=
    GCS_BUCKET_URI=gs://partyscene
    GCS_BUCKET_NAME=partyscene
    LOCATION=us-central1
    STREAM_TYPE={STREAM_TYPE}
    OUTPUT_URI=
    # GOOGLE_APPLICATION_CREDENTIALS={GOOGLE_APPLICATION_CREDENTIALS}
    SCHEMA_FILE=init/schema.surql
    # /home/ for Docker init/ for debz
    asyncio_mode = auto
    asyncio_default_fixture_loop_scope = session
    MEDIA_MICROSERVICE_URL=
    # RABBITMQ_URI={RABBITMQ_URI}
    RABBITMQ_URI={RABBITMQ_URI}
    RABBITMQ_MEDIA_QUEUE={RABBITMQ_MEDIA_QUEUE}
    RABBITMQ_R18E_QUEUE={RABBITMQ_R18E_QUEUE}
    GOOGLE_CLIENT_ID={GOOGLE_CLIENT_ID}
    SURREAL_NAMESPACE={SURREAL_NAMESPACE}
    SURREAL_DATABASE={SURREAL_DATABASE}
    PAYMENT_WEBHOOK_URL={PAYMENT_WEBHOOK_URL}
    STRIPE_WEBHOOK_SECRET={STRIPE_WEBHOOK_SECRET}
    STRIPE_PUB_KEY={STRIPE_PUB_KEY}
    STRIPE_PRIV_KEY={STRIPE_PRIV_KEY}
    KEK_SECRET_NAME={KEK_SECRET_NAME}
    PROJECT_NUMBER={PROJECT_NUMBER}
    DB_URL={DB_URL}
    DB_NS={DB_NS}
    DB_NAME={DB_NAME}
    DB_USER={DB_USER}
    DB_PASS={DB_PASS}
    JWT_SECRET_KEY={JWT_SECRET_KEY}
    GCP_PROJECT_ID={GCP_PROJECT_ID}
    GCP_BUCKET_NAME={GCP_BUCKET_NAME}
    GOOGLE_APPLICATION_CREDENTIALS={GOOGLE_APPLICATION_CREDENTIALS}
    GCLOUD_AUTH_DIR={GCLOUD_AUTH_DIR}